<!DOCTYPE html>
<html lang="en">

<%- include('partials/header') %>

    <body>
        <%- include('partials/nav') %>
            <div class="container">
                <h1>Harry Potter Characters</h1>
                <div class="cards-grid">
                    <% character.forEach(char=> { %>
                        <article class="card character-card">
                            <div class="card-media">
                                <img src="<%= char.image %>" alt="Image of <%= char.fullName %>">
                            </div>
                            <div class="card-body">
                                <h2>
                                    <%= char.fullName %>
                                </h2>
                                <div class="meta">House: <%= char.hogwartsHouse || 'Unknown' %>
                                </div>
                                <p>Played By: <%= char.interpretedBy || '—' %>
                                </p>
                            </div>
                        </article>
                        <% }) %>
                </div>
            </div>
    </body>

    <%- include('partials/footer') %>

</html>