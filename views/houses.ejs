<!DOCTYPE html>
<html lang="en">

<%- include('partials/header') %>

    <body>
        <%- include('partials/nav') %>
            <div class="container">
                <h1>Harry Potter Houses</h1>
                <% houses.forEach(house=> { %>
                    <div class="card">
                        <h2>
                            <%= house.house %>
                        </h2>
                        <p>Founder: <%= house.founder %>
                        </p>
                        <p>Animal: <%= house.animal %>
                        </p>
                        <p>Emoji: <%= house.emoji %> - Colors: <%= house.colors %>
                    </div>
                    <% }); %>
            </div>
    </body>

    <%- include('partials/footer') %>

</html>