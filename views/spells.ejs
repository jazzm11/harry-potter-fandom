<!DOCTYPE html>
<html lang="en">

<%- include('partials/header') %>

    <body>
        <%- include('partials/nav') %>
            <div class="container">
                <h1>Harry Potter Spells</h1>
                <% spells.forEach(spell=> { %>
                    <div class="card">
                        <h2>
                            <%= spell.spell %>
                        </h2>
                        <p>Use: <%= spell.use %>
                        </p>
                    </div>
                    <% }); %>
            </div>
    </body>

    <%- include('partials/footer') %>

</html>